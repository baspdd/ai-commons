{
  "mcpServers": {
    "codegraph": {
      "command": "codegraph",
      "args": [
        "serve",
        "--mcp"
      ],
      "env": {},
      "disabled": false,
      "autoApprove": [
        "codegraph_status",
        "codegraph_context",
        "codegraph_search",
        "codegraph_files",
        "codegraph_node",
        "codegraph_explore",
        "codegraph_trace",
        "codegraph_callers",
        "codegraph_callees",
        "codegraph_impact"
      ]
    }
  }
}

